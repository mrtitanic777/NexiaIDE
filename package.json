{
  "name": "nexia-ide",
  "displayName": "Nexia IDE",
  "description": "Xbox 360 Development Environment & Adaptive C++ Tutor",
  "version": "3.3.0-dev",
  "author": "Nexia",
  "license": "MIT",
  "main": "dist/main/main.js",
  "scripts": {
    "build": "tsc && node scripts/copy-assets.js",
    "start": "npm run build && electron .",
    "dist": "npm run build && npm run build:helpers && electron-builder --win",
    "dist:installer": "npm run build && npm run build:helpers && electron-builder --win --config.win.target=nsis",
    "dev": "npm run build && electron .",
    "build:helpers": "node scripts/build-extract-sdk.js && node scripts/build-core.js",
    "build:core": "node scripts/build-core.js",
    "test:core": "node scripts/build-core.js && node core/test/toolchain-parity.js && node core/test/env-parity.js && node core/test/xex-parity.js && node core/test/project-parity.js && node core/test/templates-parity.js && node core/test/names-parity.js && node core/test/json-escape-parity.js && node core/test/create-parity.js && node core/test/jsonwrite-parity.js && node core/test/vsimport-parity.js && node core/test/search-parity.js && node core/test/emulator-parity.js && node core/test/extensions-parity.js && node core/test/buildsystem-parity.js && node core/test/devkit-parity.js"
  },
  "build": {
    "appId": "com.nexia.ide",
    "productName": "NexiaIDE",
    "copyright": "Copyright 2026 Nexia",
    "forceCodeSigning": false,
    "artifactName": "NexiaIDE-${version}.${ext}",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "publisherName": "Nexia",
      "legalTrademarks": "Nexia IDE",
      "fileAssociations": [
        {
          "ext": "nexproj",
          "name": "Nexia IDE Project",
          "description": "Nexia IDE Project File",
          "icon": "resources/icon.ico"
        }
      ]
    },
    "portable": {
      "artifactName": "NexiaIDE.exe",
      "unpackDirName": "NexiaIDE-data"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Nexia IDE",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "include": "build/installer.nsh",
      "artifactName": "NexiaSetup-${version}.${ext}"
    },
    "files": [
      "dist/main/**/*",
      "dist/renderer/**/*",
      "dist/shared/**/*",
      "resources/**/*",
      "!node_modules/monaco-editor/dev/**/*",
      "!node_modules/monaco-editor/esm/**/*",
      "!node_modules/monaco-editor/min-maps/**/*"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources"
      },
      {
        "from": "PackedFiles/vcredist_x86.exe",
        "to": "vcredist_x86.exe"
      },
      {
        "from": "dist/extract_sdk.exe",
        "to": "extract_sdk.exe"
      }
    ],
    "asarUnpack": []
  },
  "dependencies": {
    "monaco-editor": "^0.45.0",
    "marked": "^15.0.0",
    "highlight.js": "^11.10.0"
  },
  "devDependencies": {
    "@types/node": "^16.18.0",
    "electron": "^22.3.27",
    "electron-builder": "^24.9.0",
    "typescript": "^5.3.0"
  }
}
