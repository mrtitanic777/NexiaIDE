<UserControl x:Class="NexiaUI.SearchPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Foreground="{StaticResource Text}">
    <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="SEARCH" FontWeight="SemiBold"
                   FontSize="11" Margin="10,8" Foreground="{StaticResource Accent}"/>
        <DockPanel DockPanel.Dock="Top" Margin="8,0,8,6">
            <Button DockPanel.Dock="Right" Content="Find" Width="52" Margin="6,0,0,0"
                    Click="OnFind" Background="{StaticResource ChromeBg}" Foreground="{StaticResource Text}"/>
            <TextBox x:Name="Query" KeyDown="OnQueryKey" Background="{StaticResource DeepBg}"
                     Foreground="{StaticResource Text}" BorderBrush="{StaticResource Divider}" Padding="4,3"/>
        </DockPanel>
        <TextBlock DockPanel.Dock="Top" x:Name="Summary" Margin="10,0,0,4"
                   Foreground="{StaticResource TextDim}" FontSize="11"/>
        <ListBox x:Name="Results" Background="Transparent" BorderThickness="0"
                 Foreground="{StaticResource Text}" SelectionChanged="OnPick"
                 HorizontalContentAlignment="Stretch">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="0,1">
                        <TextBlock Foreground="{StaticResource Accent}" FontSize="11">
                            <Run Text="{Binding File, Mode=OneWay}"/><Run Text=":"/><Run Text="{Binding Line, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Text="{Binding Preview}" Foreground="{StaticResource TextDim}"
                                   FontFamily="Consolas" FontSize="11" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</UserControl>
