<UserControl x:Class="NexiaUI.StubPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Foreground="{StaticResource Text}">
    <DockPanel>
        <TextBlock DockPanel.Dock="Top" x:Name="TitleText" FontWeight="SemiBold"
                   FontSize="11" Margin="10,8" Foreground="{StaticResource Accent}"/>
        <StackPanel Margin="12,4">
            <TextBlock x:Name="BodyText" TextWrapping="Wrap" Foreground="{StaticResource TextDim}"
                       FontSize="12" LineHeight="18"/>
            <TextBlock Text="Being rebuilt in WPF." Margin="0,12,0,0"
                       Foreground="#66666E" FontStyle="Italic" FontSize="11"/>
        </StackPanel>
    </DockPanel>
</UserControl>
