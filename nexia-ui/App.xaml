<Application x:Class="NexiaUI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- Theme brushes, kept in one place so a skin (including ImageBrush
             textures) can replace them without touching the window. -->
        <SolidColorBrush x:Key="AppBg"        Color="#1E1E22"/>
        <SolidColorBrush x:Key="PanelBg"      Color="#232327"/>
        <SolidColorBrush x:Key="DeepBg"       Color="#141416"/>
        <SolidColorBrush x:Key="ChromeBg"     Color="#2A2A30"/>
        <SolidColorBrush x:Key="Divider"      Color="#34343A"/>
        <SolidColorBrush x:Key="Text"         Color="#DDDDDD"/>
        <SolidColorBrush x:Key="TextDim"      Color="#9A9AA2"/>
        <SolidColorBrush x:Key="Accent"       Color="#5ADCCB"/>
    </Application.Resources>
</Application>
